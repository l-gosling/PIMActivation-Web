# Entra ID OAuth Configuration
ENTRA_TENANT_ID=your-tenant-id.onmicrosoft.com
ENTRA_CLIENT_ID=your-app-client-id
ENTRA_CLIENT_SECRET=your-app-client-secret
ENTRA_REDIRECT_URI=https://{fqdn}/api/auth/callback

# HTTPS Configuration
# Port mapped on the host (default 443)
HTTPS_PORT=443

# Pode Server Configuration
PODE_PORT=8080
PODE_MODE=production

# Logging
LOG_LEVEL=Information

# Session Configuration
SESSION_TIMEOUT=43200

# Feature Flags
INCLUDE_ENTRA_ROLES=true
INCLUDE_GROUPS=true
INCLUDE_AZURE_RESOURCES=false
# Enable Entra audit log sync in history (requires AuditLog.Read.All permission)
INCLUDE_AUDIT_LOGS=true

# Custom Theme (optional — defaults to Microsoft Fluent Design colors)
# THEME_PRIMARY_COLOR=#0078D4
# THEME_SECONDARY_COLOR=#107C10
# THEME_DANGER_COLOR=#DA3B01
# THEME_WARNING_COLOR=#FFB900
# THEME_SUCCESS_COLOR=#107C10
# THEME_FONT_FAMILY=Segoe UI, -apple-system, sans-serif
# THEME_SECTION_HEADER_COLOR=#0078D4
# THEME_ENTRA_COLOR=#0078D4
# THEME_GROUP_COLOR=#107C10
# THEME_AZURE_COLOR=#003067

# Copyright text shown in footer (optional — hidden if empty)
# APP_COPYRIGHT=© 2026 Your Organization. All rights reserved.

# Graph API Configuration
GRAPH_API_TIMEOUT=30000
GRAPH_BATCH_SIZE=20
